# Postgres
POSTGRES_USER=asobu
POSTGRES_PASSWORD=asobu_secret
POSTGRES_DB=asobu_photos

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=photos

# Public base URL used to build share links (where the frontend is reachable)
PUBLIC_BASE_URL=http://localhost:8080

# Host ports (change these if the defaults are already in use on your machine)
FRONTEND_PORT=8080
BACKEND_PORT=3000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
